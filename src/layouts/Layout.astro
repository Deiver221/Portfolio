---
import '../styles/global.css'
import '@fontsource-variable/onest/wght.css';
interface Props {
	title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/src/assets/favico.svg" />
    <title>{title}</title>
  </head>

  <body class="bg-[#0a0a0f] text-white min-h-screen">
    <header class="fixed top-0 left-0 right-0 z-50 flex justify-center py-3">
      <nav class="flex gap-6 bg-white/5 backdrop-blur-sm border border-white/10 rounded-full px-6 py-2 text-sm">
        <a href="#proyectos" class="text-gray-300 hover:text-white transition-colors">Proyectos</a>
        <a href="#sobre-mi" class="text-gray-300 hover:text-white transition-colors">Sobre mí</a>
        <a href="#contacto" class="text-gray-300 hover:text-white transition-colors">Contacto</a>
      </nav>
    </header>

    <main class="max-w-4xl mx-auto px-6 pt-24">
      <slot />
    </main>

    <footer class="max-w-3xl mx-auto px-6 py-8 mt-20 border-t border-white/10 text-sm text-gray-500 flex justify-between">
      <span>© 2026 Deiver. Todos los derechos reservados.</span>
      <div class="flex gap-4">
        <a href="#sobre-mi" class="hover:text-white transition-colors">Sobre mí</a>
        <a href="#contacto" class="hover:text-white transition-colors">Contacto</a>
      </div>
    </footer>

  </body>
</html>

<style>
	html {
		font-family: 'Onest Variable', sans-serif;
	}
</style>